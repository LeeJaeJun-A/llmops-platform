# =============================================================================
# LLMOps Platform — Local Development
# Copy to .env and fill in your values: cp .env.example .env
# Secrets (API keys, auth) go in .env.secrets — see .env.secrets.example
# =============================================================================

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://llmops:llmops@localhost:5432/llmops

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Observability ---
LANGFUSE_HOST=http://localhost:3000
OBSERVABILITY_BACKEND=noop  # langfuse | otel | noop

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=60
