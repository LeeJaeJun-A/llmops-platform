# =============================================================================
# LLMOps Platform — Secrets
# Copy to .env.secrets and fill in your keys: cp .env.secrets.example .env.secrets
# Used by both local dev and AWS deployment.
# Upload to AWS: ./scripts/upload_secrets.sh .env.secrets
# =============================================================================

# --- LLM Providers ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Langfuse (get from Langfuse UI after deploy → Settings → API Keys) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Service Auth (comma-separated keys for clients calling this gateway) ---
API_KEYS=test-key-1
